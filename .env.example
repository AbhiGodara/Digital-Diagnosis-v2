# Groq API Keys (Insert your API key below)
GROQ_API_KEY="gsk_your_groq_api_key_here"

# LangChain / LangSmith Tracing configuration (Optional)
LANGSMITH_API_KEY="lsv2_your_langsmith_api_key_here"
LANGCHAIN_PROJECT="Digital Diagnosis"
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"

# Hugging Face Token (Optional, for downloading gated model assets if needed)
HF_TOKEN="hf_your_huggingface_token_here"

# LLM Model Name for Chatbot & Symptom Parser
LLM_MODEL_NAME="llama-3.3-70b-versatile"
